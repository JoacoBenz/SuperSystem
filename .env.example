# =============================================================================
# Copy to .env and fill in. NEVER commit real secrets — .env is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# App runtime -> pooled connection (Supavisor transaction mode, port 6543).
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-DB-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Migrations / Prisma CLI -> direct connection (port 5432, bypasses the pooler).
DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-DB-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require"
# Optional: serverless pool size per instance (default: 1 in prod, 10 in dev).
# DATABASE_POOL_MAX="1"
# Optional: PEM of the Supabase project CA to enable strict TLS verification.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# -----------------------------------------------------------------------------
# Auth (NextAuth)
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-32-byte-random-secret"

# OAuth (optional - SSO login)
AUTH_GOOGLE_CLIENT_ID=""
AUTH_GOOGLE_CLIENT_SECRET=""
AUTH_MICROSOFT_CLIENT_ID=""
AUTH_MICROSOFT_CLIENT_SECRET=""
AUTH_MICROSOFT_TENANT_ID="common"

# -----------------------------------------------------------------------------
# Encryption (app-level field encryption)
# -----------------------------------------------------------------------------
# 32-byte key, base64 or hex. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# -----------------------------------------------------------------------------
# Supabase Storage (file attachments) - use a PRIVATE bucket
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="attachments"

# -----------------------------------------------------------------------------
# Background jobs (Vercel Cron)
# -----------------------------------------------------------------------------
# Shared secret the cron route checks (Authorization: Bearer $CRON_SECRET).
CRON_SECRET=""

# -----------------------------------------------------------------------------
# External providers (optional - default to safe offline stubs if unset)
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM=""
MERCADOPAGO_ACCESS_TOKEN=""
ANTHROPIC_API_KEY=""
