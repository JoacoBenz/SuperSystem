model User {
  id            Int       @id @default(autoincrement())
  tenantId      Int       @map("tenant_id")
  name          String    @db.VarChar(150)
  email         String    @db.VarChar(255)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  departmentId  Int?      @map("department_id")
  orgRole       String    @default("member") @map("org_role") @db.VarChar(20)
  active        Boolean   @default(true)
  oauthProvider String?   @map("oauth_provider") @db.VarChar(20)
  oauthSub      String?   @map("oauth_sub") @db.VarChar(255)
  version       Int       @default(1)
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  createdBy     Int?      @map("created_by")
  updatedBy     Int?      @map("updated_by")

  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department          Department?      @relation("user_department", fields: [departmentId], references: [id])
  userRoles           UserRole[]
  delegationsGiven    Delegation[]     @relation("delegation_delegator")
  delegationsReceived Delegation[]     @relation("delegation_delegate")
  auditLogs           AuditLog[]
  notifications       Notification[]
  invitationCodes     InvitationCode[] @relation("invitation_creator")

  @@unique([tenantId, id])
  @@unique([tenantId, email])
  @@unique([oauthProvider, oauthSub])
  @@map("users")
}
