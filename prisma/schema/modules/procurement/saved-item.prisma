model ProcurementSavedItem {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  userId      Int      @map("user_id")
  description String   @db.VarChar(255)
  unit        String   @default("units") @db.VarChar(50)
  estimatedPrice Decimal? @map("estimated_price") @db.Decimal(15, 2)
  productUrl  String?  @map("product_url") @db.VarChar(500)
  useCount    Int      @default(1) @map("use_count")
  lastUsedAt  DateTime @default(now()) @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([tenantId, userId, description])
  @@index([tenantId, userId])
  @@map("procurement_saved_items")
}
